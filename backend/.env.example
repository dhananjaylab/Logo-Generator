# Logo Generator - Backend Environment Variables
# Copy this file to .env and update with your production values

# ─────────────────────────────────────────────────────────────────────────────
# Environment & Deployment
# ─────────────────────────────────────────────────────────────────────────────

# Deployment environment: 'development', 'staging', or 'production'
# Affects security checks, logging, and feature flags
ENV=development

# Frontend URL(s) for CORS - comma-separated for multiple origins
# Example: https://app.example.com,https://mobile.example.com
# CRITICAL: Never use wildcard (*) with credentials=true in production
ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Authentication (Clerk)
# ─────────────────────────────────────────────────────────────────────────────

# Clerk JWKS URL for JWT validation
# Get from Clerk dashboard: https://dashboard.clerk.com
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.com/.well-known/jwks.json

# Expected JWT audience (usually your frontend URL)
CLERK_AUDIENCE=http://localhost:3000

# Development token bypass (DEV ONLY - automatically rejected in production)
# Remove or leave empty in production builds
DEV_TOKEN=logo-forge-dev-2026

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (preferably with asyncpg driver)
# Example: postgresql+asyncpg://user:password@localhost:5432/logo_generator
# Supports Neon.tech URLs (automatically converts postgresql:// to postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/logo_generator

# ─────────────────────────────────────────────────────────────────────────────
# Redis & Background Jobs (ARQ)
# ─────────────────────────────────────────────────────────────────────────────

# Redis URL for job queue and rate limit state
# CRITICAL: This must be set in production for rate limiting and job persistence
# Example: redis://user:password@redis.example.com:6379/0
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI (DALL-E 3)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key for DALL-E 3 logo generation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_test_...

# ─────────────────────────────────────────────────────────────────────────────
# Google Generative AI (Gemini)
# ─────────────────────────────────────────────────────────────────────────────

# Google Generative AI API key for Gemini vision logo generation
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyD...

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare R2 (Image Storage)
# ─────────────────────────────────────────────────────────────────────────────

# R2 bucket name
R2_BUCKET_NAME=logo-generator-images

# R2 credentials (create from Cloudflare dashboard)
R2_ACCESS_KEY_ID=abc123...
R2_SECRET_ACCESS_KEY=xyz789...

# R2 endpoint URL
# Format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://account-id.r2.cloudflarestorage.com

# Optional: Public domain for R2 images (if configured with custom domain)
# If not set, falls back to: {R2_ENDPOINT_URL}/{R2_BUCKET_NAME}
R2_PUBLIC_DOMAIN=https://images.yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────

# Per-minute rate limit (e.g., "10/minute" = 10 requests per minute per IP)
RATE_LIMIT_PER_MINUTE=10/minute

# Per-day rate limit (e.g., "200/day" = 200 requests per day per IP)
RATE_LIMIT_PER_DAY=200/day

# ─────────────────────────────────────────────────────────────────────────────
# Logging & Observability
# ─────────────────────────────────────────────────────────────────────────────

# Log file path (optional, logs to stdout if not set)
# Example: /var/log/logo-generator/backend.log
LOG_FILE=

# Sentry DSN for error tracking and performance monitoring
# Get from: https://sentry.io/onboarding/
# Leave empty to disable Sentry
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Host to bind to
HOST=0.0.0.0

# Port to bind to
PORT=8000

# Number of worker processes (for gunicorn/production)
# Rule of thumb: CPU cores * 2 + 1
WORKERS=5

# ─────────────────────────────────────────────────────────────────────────────
# Feature Flags (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Enable DALL-E 3 logo generation
ENABLE_DALLE=true

# Enable Gemini logo generation
ENABLE_GEMINI=true

# Maximum image size for uploads (in MB)
MAX_IMAGE_SIZE_MB=10
