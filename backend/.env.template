# 🎨 LogoForge AI - Backend Environment Template
# Copy this file to .env and fill in your actual credentials.

# AI API Keys (Required)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=sk-your_openai_api_key_here

# Cloudflare R2 (Storage & CDN)
R2_BUCKET_NAME=your_bucket_name
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=https://your-public-domain.com

# Database (PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/logoforge

# Redis (ARQ Worker Queue)
REDIS_URL=redis://localhost:6379

# Clerk Authentication (Required for Production)
# Get JWKS URL from Clerk Dashboard → API Keys → JWKS Public Keys
CLERK_JWKS_URL=your_clerk_jwks_url_here
# Leave empty to disable Clerk validation in development
# CLERK_JWKS_URL=https://example.clerk.accounts.com/.well-known/jwks.json

# Security (Development Token)
DEV_TOKEN=logo-forge-dev-2026

# Rate Limiting & Misc
RATE_LIMIT_PER_MINUTE="10/minute"
RATE_LIMIT_PER_DAY="200/day"

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
