# 🎨 LogoForge AI - Backend Environment Template
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control.

# ── AI API Keys (Required) ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=sk-your_openai_api_key_here

# Gemini image generation model
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# OpenAI image performance knobs
OPENAI_IMAGE_TIMEOUT=180
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_FORMAT=jpeg
OPENAI_IMAGE_COMPRESSION=85

# ── Cloudflare R2 (Storage & CDN) ───────────────────────────────────────────
R2_BUCKET_NAME=your_bucket_name
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_SESSION_TOKEN=
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=https://your-public-domain.com

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/logoforge

# ── Redis (ARQ Worker Queue) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── ARQ Worker Tuning ────────────────────────────────────────────────────────
DALLE_WORKER_MAX_TRIES=3
DALLE_WORKER_TIMEOUT=100
DALLE_WORKER_MAX_JOBS=5
GEMINI_WORKER_MAX_TRIES=3
GEMINI_WORKER_TIMEOUT=60
GEMINI_WORKER_MAX_JOBS=10

# ── Clerk Authentication (Required for Production) ───────────────────────────
CLERK_JWKS_URL=your_clerk_jwks_url_here

# ── Security: Dev Token (Local Development Only) ────────────────────────────
#
# SECURITY (P1.3): DEV_TOKEN rules
#
#   1. Generate a fresh, unique token per developer — never share or reuse:
#        python -c "import secrets; print(secrets.token_hex(32))"
#
#   2. DEV_TOKEN is a SERVER-ONLY environment variable.  It must never be
#      prefixed NEXT_PUBLIC_ or appear in the frontend build artifact.
#
#   3. ALLOW_DEV_TOKEN must be explicitly set to "true" to activate the bypass.
#      It is hard-blocked in ENV=production and ENV=staging regardless.
#
#   4. Both variables must be absent from any environment above local dev.
#
DEV_TOKEN=replace-with-output-of-python-secrets-token-hex-32
ALLOW_DEV_TOKEN=true

# ── Privacy (P1.4): IP Anonymisation Salt ────────────────────────────────────
#
# A secret salt used to pseudonymise IP addresses before storage.
# Without this, no IP-derived data is stored at all (fail-safe).
#
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Rules:
#   - Keep this secret and stable; rotating it orphans all existing ip_hash values.
#   - Never commit the actual value to version control.
#   - Use a different value per environment (dev / staging / prod).
#
IP_HASH_SALT=replace-with-output-of-python-secrets-token-hex-32

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10/minute
RATE_LIMIT_PER_DAY=200/day

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Environment ──────────────────────────────────────────────────────────────
# Valid values: development | staging | production
ENV=development

# ── Observability ────────────────────────────────────────────────────────────
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc
# Set LOG_LEVEL=DEBUG to enable SQL query shape logging (never logs values)
LOG_LEVEL=INFO
