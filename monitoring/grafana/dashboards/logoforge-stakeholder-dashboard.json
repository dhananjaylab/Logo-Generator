{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Stakeholder-friendly overview of traffic, latency, reliability, readiness, capacity, and cost. Show trends over time and keep the board focused on a few clear signals.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Traffic: Requests per Hour",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (generator) (rate(logoforge_generation_requests_total[5m])) * 3600",
          "legendFormat": "{{generator}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "title": "Readiness: Core Services",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "logoforge_component_ready{component=\"api\"}",
          "legendFormat": "API",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "logoforge_component_ready{component=\"redis\"}",
          "legendFormat": "Redis",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "logoforge_component_ready{component=\"db\"}",
          "legendFormat": "Postgres",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "logoforge_component_ready{component=\"openai\"}",
          "legendFormat": "OpenAI",
          "instant": true
        },
        {
          "refId": "E",
          "expr": "logoforge_component_ready{component=\"gemini\"}",
          "legendFormat": "Gemini",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "title": "Latency: Generation and R2 Uploads",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le, generator) (rate(logoforge_generation_latency_seconds_bucket[5m])))",
          "legendFormat": "gen p50 {{generator}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, generator) (rate(logoforge_generation_latency_seconds_bucket[5m])))",
          "legendFormat": "gen p95 {{generator}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.95, sum by (le, status) (rate(logoforge_r2_upload_latency_seconds_bucket[5m])))",
          "legendFormat": "R2 p95 {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 4,
      "title": "Capacity: Queue Depth vs Worker Limits",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "logoforge_queue_depth",
          "legendFormat": "queue depth {{queue}}"
        },
        {
          "refId": "B",
          "expr": "logoforge_worker_max_jobs",
          "legendFormat": "max jobs {{queue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 4,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "title": "Reliability: Errors, Retries, and DLQ",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (source) (rate(logoforge_errors_total[5m]))",
          "legendFormat": "errors {{source}}"
        },
        {
          "refId": "B",
          "expr": "sum by (generator) (rate(logoforge_job_retries_total[5m]))",
          "legendFormat": "retries {{generator}}"
        },
        {
          "refId": "C",
          "expr": "sum by (queue, generator) (rate(logoforge_dlq_jobs_total[5m]))",
          "legendFormat": "dlq {{queue}} {{generator}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 6,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 6,
      "title": "Cost: Estimated Spend by Generator",
      "description": "P3.2 — cumulative estimated USD spend, derived from logoforge_generation_cost_usd_total. Estimates only, not exact billing reconciliation — see config.GENERATION_COST_USD.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (generator) (logoforge_generation_cost_usd_total)",
          "legendFormat": "cumulative {{generator}}"
        },
        {
          "refId": "B",
          "expr": "sum by (generator) (rate(logoforge_generation_cost_usd_total[1h])) * 3600",
          "legendFormat": "hourly rate {{generator}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["last"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "title": "Safety: Content Moderation Blocks",
      "description": "P3.1 — generation requests blocked by content moderation, broken out by category.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (category) (rate(logoforge_moderation_blocked_total[1h])) * 3600",
          "legendFormat": "{{category}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 60,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
